/**
 * apps-script-verifier.gs (example)
 *
 * Drop this into the Google Apps Script that backs the contact form at
 * /content/privacy/. It adds three server-side gates before the form
 * payload is accepted:
 *
 *   1. Cloudflare Turnstile token verification
 *   2. Honeypot check (website + phone)
 *   3. Minimum dwell time check (>= 2.5s between form load and submit)
 *
 * SETUP
 * -----
 * In the Apps Script editor:
 *   1. Project Settings -> Script Properties -> Add property
 *        Property: TURNSTILE_SECRET
 *        Value:    <your Turnstile secret key>
 *      (Get the key pair at https://dash.cloudflare.com Turnstile section.)
 *
 *   2. Replace the existing doPost(e) with handleContactSubmission(e), or
 *      call handleContactSubmission(e) from your existing doPost wrapper
 *      and forward to your own processing only when it returns { ok: true }.
 *
 *   3. In /content/privacy/index.qmd, replace REPLACE_WITH_TURNSTILE_SITEKEY
 *      with the matching Turnstile site key so the widget renders and
 *      attaches a cf-turnstile-response field to the submission.
 *
 * Notes:
 * - HtmlService cannot read the client IP, so remoteip is left blank.
 *   Cloudflare still verifies the token's freshness and origin.
 * - All rejections return JSON so the client (privacyForm.js) can show a
 *   useful status message; the iframe-based form ignores the body but
 *   still benefits from the request being short-circuited before any
 *   email/spreadsheet side effect.
 */

var MIN_DWELL_MS = 2500;
var TURNSTILE_VERIFY_URL =
  'https://challenges.cloudflare.com/turnstile/v0/siteverify';

function doPost(e) {
  var gate = handleContactSubmission(e);
  if (!gate.ok) return gate.response;

  // ----- your existing processing goes here -----
  // e.g.  appendToSheet(e.parameter);
  //       sendNotificationEmail(e.parameter);

  return jsonResponse({ ok: true });
}

function handleContactSubmission(e) {
  var params = (e && e.parameter) || {};

  // 1. Honeypot
  if (notEmpty(params.website) || notEmpty(params.phone)) {
    return { ok: false, response: jsonResponse({ ok: false, reason: 'honeypot' }) };
  }

  // 2. Dwell time
  var loadedAt = Number(params.formLoadedAt || 0);
  if (!loadedAt || Date.now() - loadedAt < MIN_DWELL_MS) {
    return { ok: false, response: jsonResponse({ ok: false, reason: 'too-fast' }) };
  }

  // 3. Turnstile (only enforced once TURNSTILE_SECRET is set)
  var secret = PropertiesService.getScriptProperties()
    .getProperty('TURNSTILE_SECRET');
  if (secret) {
    var token = params['cf-turnstile-response'];
    if (!token) {
      return { ok: false, response: jsonResponse({ ok: false, reason: 'turnstile-missing' }) };
    }
    var verify = verifyTurnstile(secret, token);
    if (!verify.success) {
      return {
        ok: false,
        response: jsonResponse({
          ok: false,
          reason: 'turnstile-failed',
          detail: verify['error-codes'] || []
        })
      };
    }
  }

  return { ok: true };
}

function verifyTurnstile(secret, token) {
  try {
    var resp = UrlFetchApp.fetch(TURNSTILE_VERIFY_URL, {
      method: 'post',
      muteHttpExceptions: true,
      payload: { secret: secret, response: token }
    });
    return JSON.parse(resp.getContentText() || '{}');
  } catch (err) {
    Logger.log('Turnstile fetch failed: ' + err);
    return { success: false, 'error-codes': ['fetch-failed'] };
  }
}

function jsonResponse(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

function notEmpty(value) {
  return typeof value === 'string' && value.trim().length > 0;
}
