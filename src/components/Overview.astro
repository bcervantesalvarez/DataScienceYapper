---
// src/components/Overview.astro
// Plain-language summary box. Use at the top of any project, blog post,
// or talk to give a non-specialist a 30-second read before the
// technical body. Style: warm-toned panel with a clear eyebrow label,
// readable typography, and a subtle left rule that ties it to the
// editorial design.
interface Props {
  /** Optional override for the eyebrow label */
  eyebrow?: string;
  /** Reading-level cue shown below the body, e.g. "Plain-language summary" */
  note?: string;
}

const { eyebrow = 'Overview', note = 'Plain-language summary · ~8th-grade reading level' } = Astro.props;
---
<aside class="not-prose my-8 rounded-xl border border-rule bg-surface-soft px-6 py-6 md:px-8 md:py-7">
  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted m-0 mb-3">
    {eyebrow}
  </p>
  <div class="text-body text-base leading-relaxed [&>p]:m-0 [&>p+p]:mt-3">
    <slot />
  </div>
  {note && (
    <p class="text-xs text-muted mt-4 m-0 italic">{note}</p>
  )}
</aside>
