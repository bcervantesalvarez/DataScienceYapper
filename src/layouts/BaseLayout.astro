---
// src/layouts/BaseLayout.astro
// Site shell: <html>, <head>, navbar, footer. Every page should use this.
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import ScrollTop from '@components/ScrollTop.astro';
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Epsilon Labs',
  description = 'Statistical consulting, predictive modeling, and decision-grade analytics by Brian Cervantes Alvarez.',
  ogImage = '/images/preview.png',
} = Astro.props;

const fullTitle = title === 'Epsilon Labs' ? title : `${title} · Epsilon Labs`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- OpenGraph / Twitter -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Type -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500..800&display=swap"
  />

  <!-- KaTeX (only renders any inline `<span class="math">` that survived
       the qmd → MDX port; otherwise inert). -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
    crossorigin="anonymous"
  />

  <!-- Set theme before paint to avoid flash -->
  <script is:inline>
    (function () {
      try {
        const stored = localStorage.getItem('theme');
        const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', stored || prefers);
      } catch (e) { /* no-op */ }
    })();
  </script>
</head>
<body class="bg-bg text-body font-sans text-base">
  <Navbar />
  <main>
    <slot />
  </main>
  <Footer />
  <ScrollTop />

  <!-- Iframe enhancements:
       (1) Ensure every iframe allows fullscreen (presentations + apps
           that arrived inside imported Quarto HTML bodies have no such
           attribute by default).
       (2) Inject a small "Fullscreen" button overlay on every iframe
           inside .article-body so visitors don't have to know about
           revealjs's F key. -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('iframe').forEach((f) => {
        const cur = f.getAttribute('allow') || '';
        if (!cur.includes('fullscreen')) {
          f.setAttribute('allow', cur ? `${cur}; fullscreen` : 'fullscreen');
        }
        f.setAttribute('allowfullscreen', '');
      });

      document.querySelectorAll('.article-body iframe').forEach((f) => {
        // Wrap each iframe in a positioned container so we can place a
        // fullscreen-toggle button on top without disturbing layout.
        if (f.parentElement && f.parentElement.classList.contains('iframe-shell')) return;

        const shell = document.createElement('div');
        shell.className = 'iframe-shell relative my-6';
        f.parentElement?.insertBefore(shell, f);
        shell.appendChild(f);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('aria-label', 'Open presentation in fullscreen');
        btn.className =
          'iframe-fs absolute top-3 right-3 z-10 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-full bg-ink text-bg shadow-md hover:bg-accent-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink';
        btn.innerHTML =
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg><span>Fullscreen</span>';
        btn.addEventListener('click', () => {
          if (document.fullscreenElement) {
            document.exitFullscreen();
            return;
          }
          // Request on the iframe itself so revealjs sees the resize and
          // recomputes slide scale.
          (f.requestFullscreen?.bind(f) ||
            f.webkitRequestFullscreen?.bind(f) ||
            (() => {}))();
        });
        shell.appendChild(btn);
      });
    });
  </script>
</body>
</html>
