---
// src/layouts/BaseLayout.astro
// Site shell: <html>, <head>, navbar, footer. Every page should use this.
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import ScrollTop from '@components/ScrollTop.astro';
import SearchModal from '@components/SearchModal.astro';
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
  // Path under /og/ for a build-time generated card, e.g. "blog/my-post".
  // When omitted, the shared /og/default.png is used.
  ogPath?: string;
  // Escape hatch for explicit static images (e.g. legacy assets).
  ogImage?: string;
}

const {
  title = 'Epsilon Labs',
  description = 'Statistical consulting, predictive modeling, and decision-grade analytics by Brian Cervantes Alvarez.',
  ogPath,
  ogImage,
} = Astro.props;

const fullTitle = title === 'Epsilon Labs' ? title : `${title} · Epsilon Labs`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const resolvedOg = ogImage ?? `/og/${ogPath ?? 'default'}.png`;
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link
    rel="alternate"
    type="application/rss+xml"
    title="Epsilon Labs — Insights"
    href="/blog/rss.xml"
  />

  <!-- OpenGraph / Twitter -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL(resolvedOg, Astro.site)} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Type -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500..800&display=swap"
  />

  <!-- KaTeX: render math left over from the Quarto export. The bodies
       carry raw LaTeX inside <span class="math inline|display"> nodes;
       we render those in place after DOMContentLoaded. -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
    crossorigin="anonymous"
  />
  <script
    is:inline
    defer
    src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"
    crossorigin="anonymous"
  ></script>

  <!-- JSON-LD: Person + Organization. Search engines surface these
       in the knowledge panel + as rich results. -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'Person',
        '@id': 'https://epsilon-labs.org/#brian',
        name: 'Brian Cervantes Alvarez',
        url: 'https://epsilon-labs.org/',
        image: 'https://epsilon-labs.org/images/profile.jpg',
        sameAs: [
          'https://linkedin.com/in/bcervantesalvarez',
          'https://github.com/bcervantesalvarez',
        ],
        jobTitle: 'Business Intelligence Analyst',
        worksFor: {
          '@type': 'GovernmentOrganization',
          name: 'Oregon Department of Education',
          url: 'https://www.oregon.gov/ode/',
        },
        alumniOf: [
          { '@type': 'CollegeOrUniversity', name: 'Oregon State University', url: 'https://stat.oregonstate.edu/' },
          { '@type': 'CollegeOrUniversity', name: 'Willamette University', url: 'https://willamette.edu/academics/computing/data-science/' },
          { '@type': 'CollegeOrUniversity', name: 'Linfield University', url: 'https://www.linfield.edu/' },
        ],
        knowsAbout: [
          'Statistics', 'Statistical consulting', 'Predictive modeling',
          'Machine learning', 'Bayesian inference', 'Experimental design',
          'Data visualization', 'R', 'Python', 'SQL',
        ],
      },
      {
        '@type': 'Organization',
        '@id': 'https://epsilon-labs.org/#epsilon-labs',
        name: 'Epsilon Labs',
        url: 'https://epsilon-labs.org/',
        founder: { '@id': 'https://epsilon-labs.org/#brian' },
        description: 'Statistical consulting, predictive modeling, and decision-grade analytics.',
      },
      {
        '@type': 'WebSite',
        '@id': 'https://epsilon-labs.org/#website',
        url: 'https://epsilon-labs.org/',
        name: 'Epsilon Labs',
        publisher: { '@id': 'https://epsilon-labs.org/#epsilon-labs' },
        inLanguage: 'en-US',
      },
    ],
  })} />

  <!-- Set theme before paint to avoid flash -->
  <script is:inline>
    (function () {
      try {
        const stored = localStorage.getItem('theme');
        const prefers = window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', stored || prefers);
      } catch (e) { /* no-op */ }
    })();
  </script>
</head>
<body class="bg-bg text-body font-sans text-base">
  <Navbar />
  <main>
    <slot />
  </main>
  <Footer />
  <ScrollTop />
  <SearchModal />

  <!-- KaTeX: render math left over from the Quarto export -->
  <script>
    function renderArticleMath() {
      // @ts-ignore — katex is loaded via the CDN <script> in <head>
      const k = window.katex;
      if (!k) return false;
      document.querySelectorAll('.article-body .math').forEach((el) => {
        if (el.hasAttribute('data-katex-rendered')) return;
        const tex = (el.textContent || '').trim();
        if (!tex) return;
        const displayMode = el.classList.contains('display');
        try {
          k.render(tex, el, { throwOnError: false, displayMode, strict: 'ignore' });
          el.setAttribute('data-katex-rendered', '');
        } catch (e) {
          console.warn('KaTeX render failed:', tex, e);
        }
      });
      return true;
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        // The katex script has `defer`, so it may not be ready yet.
        if (!renderArticleMath()) {
          const retry = setInterval(() => {
            if (renderArticleMath()) clearInterval(retry);
          }, 50);
          setTimeout(() => clearInterval(retry), 5000);
        }
      });
    } else {
      renderArticleMath();
    }
  </script>

  <!-- Iframe presentation mode:
       Native iframe fullscreen often fails to trigger revealjs's resize
       handler on cross-origin embeds, leaving slides at the small
       embedded scale. Instead, we toggle a `.present` class that lifts
       the iframe into a fixed full-viewport overlay; revealjs picks up
       the natural resize and scales correctly. Esc exits. -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('iframe').forEach((f) => {
        const cur = f.getAttribute('allow') || '';
        if (!cur.includes('fullscreen')) {
          f.setAttribute('allow', cur ? `${cur}; fullscreen` : 'fullscreen');
        }
        f.setAttribute('allowfullscreen', '');
      });

      let active = null;
      const exit = () => {
        if (!active) return;
        document.documentElement.classList.remove('iframe-presenting');
        active.classList.remove('present');
        active = null;
      };

      document.querySelectorAll('.article-body iframe').forEach((f) => {
        if (f.parentElement?.classList.contains('iframe-shell')) return;

        const shell = document.createElement('div');
        shell.className = 'iframe-shell relative my-6';
        f.parentElement?.insertBefore(shell, f);
        shell.appendChild(f);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('aria-label', 'Open presentation full screen');
        btn.className =
          'iframe-fs absolute top-3 right-3 z-20 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-full bg-ink text-bg shadow-md hover:bg-accent-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink';
        btn.innerHTML =
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg><span class="fs-label">Full screen</span>';
        const setLabel = (text) => {
          const lbl = btn.querySelector('.fs-label');
          if (lbl) lbl.textContent = text;
        };
        btn.addEventListener('click', () => {
          if (shell.classList.contains('present')) {
            setLabel('Full screen');
            exit();
            return;
          }
          exit();
          shell.classList.add('present');
          document.documentElement.classList.add('iframe-presenting');
          active = shell;
          setLabel('Exit');
          // Nudge the iframe to recompute layout once the new size lands.
          requestAnimationFrame(() => {
            window.dispatchEvent(new Event('resize'));
          });
        });
        shell.appendChild(btn);

        shell.addEventListener('present:exit', () => setLabel('Full screen'));
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && active) {
          active.dispatchEvent(new Event('present:exit'));
          exit();
        }
      });
    });
  </script>
</body>
</html>
