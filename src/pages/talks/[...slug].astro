---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('talks');
  return entries.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}

type Props = { entry: CollectionEntry<'talks'> };
const { entry } = Astro.props;
const { Content } = await entry.render();
const fmt = (d: Date) => d.toLocaleDateString('en-US',
  { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-prose mx-auto px-6 pt-20 pb-16">
    <p class="text-sm text-muted m-0 mb-3">
      {fmt(entry.data.date)}{entry.data.venue ? ` · ${entry.data.venue}` : ''}
    </p>
    <h1 class="font-serif font-semibold text-ink text-5xl md:text-6xl tracking-tight leading-[1.06] m-0 mb-5">
      {entry.data.title}
    </h1>
    <p class="text-lede text-body m-0 mb-10">{entry.data.description}</p>
    <div class="prose prose-lg max-w-none text-body leading-relaxed">
      <Content />
    </div>
  </article>
</BaseLayout>
